generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SkillDifficulty {
  beginner
  intermediate
  advanced
  expert
}

enum SkillCategory {
  linux
  networking
  web
  active_directory
  windows
  privesc
  api_security
  cloud
  reverse_engineering
  malware_analysis
  forensics
  red_team
  scripting
  osint
  blue_team
  bug_bounty
  containers
  ai_security
  exploitation
}

enum RoadmapPhase {
  fondations
  intermediaire
  avance
  expert
}

enum SkillProgressStatus {
  not_started
  in_progress
  completed
}

enum ResourceType {
  article
  video
  course
  doc
}

enum MethodologyCategory {
  web
  internal
  active_directory
  wifi
  osint
  ctf
  bug_bounty
}

enum UserRole {
  member
  mentor
  ctf_manager
  documentation_manager
  infrastructure_manager
  red_team_lead
  blue_team_lead
  training_manager
  co_founder
  founder
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  displayName   String
  role          UserRole  @default(member)
  xp            Int       @default(0)
  streakCount   Int       @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())

  skillProgress   UserSkillProgress[]
  stepProgress    UserStepProgress[]
  xpEvents        XpEvent[]
  badges          UserBadge[]
  activityLogs    ActivityLog[]
  journalEntries  JournalEntry[]
  certifications  UserCertificationProgress[]
}

model Skill {
  id             String          @id @default(uuid())
  slug           String          @unique
  title          String
  description    String
  importance     String
  category       SkillCategory
  phase          RoadmapPhase
  difficulty     SkillDifficulty
  estimatedHours Int
  position       Int             @default(0)
  createdAt      DateTime        @default(now())

  prerequisites   Skill[] @relation("SkillPrerequisites")
  unlockedBySkill Skill[] @relation("SkillPrerequisites")

  resources ResourceLink[]
  labs      LabRecommendation[]
  progress  UserSkillProgress[]
}

model ResourceLink {
  id      String       @id @default(uuid())
  skillId String
  skill   Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  title   String
  url     String
  type    ResourceType

  @@index([skillId])
}

model LabRecommendation {
  id         String          @id @default(uuid())
  skillId    String
  skill      Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  title      String
  platform   String
  url        String?
  difficulty SkillDifficulty

  @@index([skillId])
}

model UserSkillProgress {
  id          String               @id @default(uuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId     String
  skill       Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)
  status      SkillProgressStatus  @default(not_started)
  completedAt DateTime?
  notes       String?

  @@unique([userId, skillId])
  @@index([userId])
}

model XpEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Methodology {
  id             String              @id @default(uuid())
  slug           String              @unique
  title          String
  category       MethodologyCategory
  objective      String
  preparation    String
  tools          String[]
  bestPractices  String
  commonMistakes String
  deliverables   String
  position       Int                 @default(0)

  steps MethodologyStep[]
}

model MethodologyStep {
  id            String      @id @default(uuid())
  methodologyId String
  methodology   Methodology @relation(fields: [methodologyId], references: [id], onDelete: Cascade)
  order         Int
  title         String
  description   String

  progress UserStepProgress[]

  @@index([methodologyId])
}

model UserStepProgress {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepId    String
  step      MethodologyStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  checked   Boolean          @default(false)
  checkedAt DateTime?

  @@unique([userId, stepId])
  @@index([userId])
}

model Badge {
  id          String @id @default(uuid())
  slug        String @unique
  title       String
  description String
  icon        String

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

// ══════════════════════════════════════════
// Progression : niveaux Bronze → Legend et journal d'activités
// ══════════════════════════════════════════

enum ActivityType {
  thm_room
  htb_easy
  htb_medium
  htb_hard
  ctf_participation
  ctf_flag
  writeup
  script
  pentest_report
  mentoring
  talk
  external_cert
}

model ActivityLog {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ActivityType
  points    Int
  note      String?
  createdAt DateTime     @default(now())

  @@index([userId])
}

// ══════════════════════════════════════════
// Journal personnel & Wiki communautaire
// ══════════════════════════════════════════

enum JournalEntryType {
  note
  writeup
  pentest_report
  incident_report
  daily
}

model JournalEntry {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      JournalEntryType
  tags      String[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId])
}

model WikiPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  category  String
  title     String
  content   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ══════════════════════════════════════════
// CTF : catégories pédagogiques et calendrier
// ══════════════════════════════════════════

enum CtfCategoryType {
  web
  crypto
  forensics
  reverse
  osint
  pwn
  stego
  mobile
  cloud
}

model CtfCategory {
  id             String          @id @default(uuid())
  slug           String          @unique
  title          String
  category       CtfCategoryType
  howToThink     String
  methodology    String
  tools          String[]
  commonMistakes String
  keyConcepts    String
  position       Int             @default(0)
}

model CtfCompetition {
  id         String @id @default(uuid())
  name       String
  frequency  String
  level      String
  categories String[]
  url        String?
  position   Int    @default(0)
}

// ══════════════════════════════════════════
// Certifications
// ══════════════════════════════════════════

enum CertificationStatus {
  planned
  studying
  passed
}

model Certification {
  id       String @id @default(uuid())
  slug     String @unique
  title    String
  level    String
  notes    String
  position Int    @default(0)

  progress UserCertificationProgress[]
}

model UserCertificationProgress {
  id              String              @id @default(uuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificationId String
  certification   Certification       @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  status          CertificationStatus @default(planned)
  updatedAt       DateTime            @updatedAt

  @@unique([userId, certificationId])
}

// ══════════════════════════════════════════
// Quiz
// ══════════════════════════════════════════

model Quiz {
  id       String        @id @default(uuid())
  title    String
  category SkillCategory

  questions QuizQuestion[]
}

model QuizQuestion {
  id            String @id @default(uuid())
  quizId        String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  prompt        String
  choices       Json
  correctIndex  Int
  explanation   String

  @@index([quizId])
}

model UserQuizAttempt {
  id         String   @id @default(uuid())
  userId     String
  quizId     String
  score      Int
  total      Int
  answeredAt DateTime @default(now())

  @@index([userId])
}

// ══════════════════════════════════════════
// Mentor IA
// ══════════════════════════════════════════

enum AiMessageRole {
  user
  assistant
}

model AiConversation {
  id        String      @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime    @default(now())

  messages AiMessage[]

  @@index([userId])
}

model AiMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AiMessageRole
  content        String
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}
