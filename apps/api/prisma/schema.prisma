generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SkillDifficulty {
  beginner
  intermediate
  advanced
  expert
}

enum SkillCategory {
  linux
  networking
  web
  active_directory
  windows
  privesc
  api_security
  cloud
  reverse_engineering
  malware_analysis
  forensics
  red_team
}

enum SkillProgressStatus {
  not_started
  in_progress
  completed
}

enum ResourceType {
  article
  video
  course
  doc
}

enum MethodologyCategory {
  web
  internal
  active_directory
  wifi
  osint
  ctf
  bug_bounty
}

enum UserRole {
  member
  mentor
  ctf_manager
  documentation_manager
  infrastructure_manager
  red_team_lead
  blue_team_lead
  training_manager
  co_founder
  founder
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  displayName   String
  role          UserRole  @default(member)
  xp            Int       @default(0)
  streakCount   Int       @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())

  skillProgress UserSkillProgress[]
  stepProgress  UserStepProgress[]
  xpEvents      XpEvent[]
  badges        UserBadge[]
}

model Skill {
  id             String          @id @default(uuid())
  slug           String          @unique
  title          String
  description    String
  importance     String
  category       SkillCategory
  difficulty     SkillDifficulty
  estimatedHours Int
  position       Int             @default(0)
  createdAt      DateTime        @default(now())

  prerequisites   Skill[] @relation("SkillPrerequisites")
  unlockedBySkill Skill[] @relation("SkillPrerequisites")

  resources ResourceLink[]
  labs      LabRecommendation[]
  progress  UserSkillProgress[]
}

model ResourceLink {
  id      String       @id @default(uuid())
  skillId String
  skill   Skill        @relation(fields: [skillId], references: [id], onDelete: Cascade)
  title   String
  url     String
  type    ResourceType

  @@index([skillId])
}

model LabRecommendation {
  id         String          @id @default(uuid())
  skillId    String
  skill      Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  title      String
  platform   String
  url        String?
  difficulty SkillDifficulty

  @@index([skillId])
}

model UserSkillProgress {
  id          String               @id @default(uuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId     String
  skill       Skill                @relation(fields: [skillId], references: [id], onDelete: Cascade)
  status      SkillProgressStatus  @default(not_started)
  completedAt DateTime?
  notes       String?

  @@unique([userId, skillId])
  @@index([userId])
}

model XpEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Methodology {
  id             String              @id @default(uuid())
  slug           String              @unique
  title          String
  category       MethodologyCategory
  objective      String
  preparation    String
  tools          String[]
  bestPractices  String
  commonMistakes String
  deliverables   String
  position       Int                 @default(0)

  steps MethodologyStep[]
}

model MethodologyStep {
  id            String      @id @default(uuid())
  methodologyId String
  methodology   Methodology @relation(fields: [methodologyId], references: [id], onDelete: Cascade)
  order         Int
  title         String
  description   String

  progress UserStepProgress[]

  @@index([methodologyId])
}

model UserStepProgress {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  stepId    String
  step      MethodologyStep  @relation(fields: [stepId], references: [id], onDelete: Cascade)
  checked   Boolean          @default(false)
  checkedAt DateTime?

  @@unique([userId, stepId])
  @@index([userId])
}

model Badge {
  id          String @id @default(uuid())
  slug        String @unique
  title       String
  description String
  icon        String

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}
